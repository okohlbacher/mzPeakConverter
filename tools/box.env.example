# Copy to tools/box.env (gitignored) and fill in. No secrets belong in the repo.
BOX_SSH=user@flash-workstation.example.edu       # box ssh destination
BOX_JUMP=you@jumphost.example.edu                # jump host (ProxyCommand)
BOX_SSH_KEY=$HOME/.ssh/id_ed25519                # key used for both hops
BOX_CONVERTER='C:\Users\User\src\mzPeakConverter\target\release\mzpeak-convert.exe'
S3_PREFIX=box-convert                            # key prefix for relayed outputs
PUT_EXPIRES=21600                                # presigned-PUT lifetime (s); must exceed convert time
# ARCHIVE=true                                   # set when raw URLs are .zip/.tgz of multi-file formats
# S3_BUCKET=v09  S3_ENDPOINT=...  S3_REGION=...  AWS_PROFILE=stackit   # s3_relay overrides
